<form class="astrolysis builder-sheet skill-builder" autocomplete="off">
  <header class="builder-hero">
    <div>
      <span class="eyebrow">{{labels.SkillBuilder}}</span>
      <input type="text" name="name" value="{{item.name}}" placeholder="{{labels.FeatureName}}" />
    </div>
    <button type="button" class="theme-toggle" data-action="toggleTheme" data-tooltip="{{labels.ToggleTheme}}" aria-label="{{labels.ToggleTheme}}">
      {{#if (eq theme "dark")}}<i class="fa-solid fa-sun"></i>{{else}}<i class="fa-solid fa-moon"></i>{{/if}}
    </button>
  </header>

  <section class="builder-body">
    <section class="builder-panel roll-profile-panel">
      <header>
        <h2>{{labels.RollProfile}}</h2>
        <output>{{skillPreview.formula}}</output>
      </header>
      <div class="builder-grid">
        <label>
          <span>{{labels.Base}}</span>
          <select name="system.base">
            {{#each baseOptions as |option|}}
            <option value="{{option.key}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
            {{/each}}
          </select>
        </label>

        <label>
          <span>{{labels.Training}}</span>
          <select name="system.training">
            {{#each trainingOptions as |option|}}
            <option value="{{option.key}}" {{#if option.selected}}selected{{/if}}>{{option.label}} (d{{option.size}})</option>
            {{/each}}
          </select>
        </label>

        <label>
          <span>{{labels.CustomModifier}}</span>
          <input type="number" name="system.modifier" value="{{system.modifier}}" />
        </label>
      </div>
      <div class="formula-preview">
        <strong>{{labels.RollFormula}}</strong> - {{skillPreview.formula}}
      </div>
    </section>

    <section class="builder-panel feature-details-panel">
      <header>
        <h2>{{labels.FeatureDetails}}</h2>
      </header>
      <label class="builder-field">
        <span>{{labels.Specialization}}</span>
        <input type="text" name="system.specialization" value="{{system.specialization}}" />
      </label>
      <label class="builder-field">
        <span>{{labels.FeatureText}}</span>
        <textarea name="system.description">{{system.description}}</textarea>
      </label>
    </section>
  </section>
</form>
