<form class="astrolysis builder-sheet archetype-builder subarchetype-builder" autocomplete="off">
  <header class="builder-hero">
    <div>
      <span class="eyebrow">{{labels.SubArchetypeBuilder}}</span>
      <input type="text" name="name" value="{{item.name}}" placeholder="{{labels.Name}}" />
    </div>
    <button type="button" class="theme-toggle" data-action="toggleTheme" data-tooltip="{{labels.ToggleTheme}}" aria-label="{{labels.ToggleTheme}}">
      {{#if (eq theme "dark")}}<i class="fa-solid fa-sun"></i>{{else}}<i class="fa-solid fa-moon"></i>{{/if}}
    </button>
  </header>

  <section class="builder-body">
    <section class="builder-panel archetype-identity-panel">
      <header>
        <h2>{{labels.MechanicalSummary}}</h2>
        <output>{{statBoostLabel}}</output>
      </header>
      <div class="builder-grid">
        <label>
          <span>{{labels.ParentArchetype}}</span>
          <input type="text" name="system.parentArchetype" value="{{system.parentArchetype}}" />
        </label>

        <label>
          <span>{{labels.Category}}</span>
          <select name="system.category">
            {{#each archetypeOptions as |option|}}
            <option value="{{option.key}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
            {{/each}}
          </select>
        </label>

        <label>
          <span>{{labels.HealthBonus}}</span>
          <input type="number" name="system.healthBonus" value="{{system.healthBonus}}" />
        </label>
      </div>
    </section>

    <section class="builder-panel base-boost-panel">
      <header>
        <h2>{{labels.BaseBoosts}}</h2>
        <output>{{statBoostLabel}}</output>
      </header>
      <div class="boost-grid">
        {{#each baseOptions as |option|}}
        <label>
          <span>{{option.label}}</span>
          <input type="number" name="system.statBonuses.{{option.key}}" value="{{lookup ../system.statBonuses option.key}}" />
        </label>
        {{/each}}
      </div>
    </section>

    <section class="builder-panel feature-details-panel">
      <header>
        <h2>{{labels.GrantedFeatures}}</h2>
        <button type="button" data-action="addFeature">
          <i class="fa-solid fa-plus"></i>
          <span>{{labels.AddFeature}}</span>
        </button>
      </header>
      <div class="feature-editor">
        {{#each featureSlots as |feature|}}
        <article>
          <div class="feature-editor-row">
            <input type="text" name="system.grantedFeatures.{{feature.index}}.name" value="{{feature.name}}" placeholder="{{@root.labels.FeatureName}}" />
            <button type="button" class="icon-button danger" data-action="removeFeature" data-feature-index="{{feature.index}}" data-tooltip="{{@root.labels.RemoveFeature}}" aria-label="{{@root.labels.RemoveFeature}}">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
          <textarea name="system.grantedFeatures.{{feature.index}}.description" placeholder="{{@root.labels.FeatureText}}">{{feature.description}}</textarea>
        </article>
        {{else}}
        <div class="empty-row">{{@root.labels.EmptyFeatures}}</div>
        {{/each}}
      </div>
    </section>

    <section class="builder-panel description-panel">
      <header>
        <h2>{{labels.Description}}</h2>
      </header>
      <textarea name="system.description">{{system.description}}</textarea>
    </section>
  </section>
</form>
