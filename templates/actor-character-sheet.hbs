<form class="astrolysis character-sheet" autocomplete="off">

  <aside class="status-rail" aria-label="{{labels.StatusRail}}">
    <div class="rail-scroll">

      <section class="portrait-panel">
        <button type="button" class="profile-wrapper image-control" data-action="editImage" data-tooltip="{{labels.ChangeImage}}" aria-label="{{labels.ChangeImage}}">
          <img class="profile-img" src="{{actor.img}}" alt="{{actor.name}}" />
          <span class="profile-overlay" aria-hidden="true">
            <i class="fa-solid fa-camera"></i>
            <span>{{labels.ChangeImage}}</span>
          </span>
        </button>
      </section>
      <div class="profile-preview" aria-hidden="true">
        <img src="{{actor.img}}" alt="" />
      </div>

      <section class="rail-card resource-card health-card">
        <header>
          <i class="fa-solid fa-heart-pulse"></i>
          <h3>{{labels.Health}}</h3>
        </header>
        <div class="resource-pair">
          <label class="sr-only" for="{{actor.id}}-health-value">{{labels.Current}} {{labels.Health}}</label>
          <input id="{{actor.id}}-health-value" type="number" name="system.health.value" value="{{system.health.value}}" />
          <span class="resource-sep">/</span>
          <label class="sr-only" for="{{actor.id}}-health-max">{{labels.Maximum}} {{labels.Health}}</label>
          <input id="{{actor.id}}-health-max" type="number" name="system.health.max" value="{{system.health.max}}" />
        </div>
      </section>

      <section class="rail-card condition-card {{#if psycheDamage.active}}condition-active{{/if}}">
        <header>
          <i class="fa-solid fa-virus-covid"></i>
          <h3>{{labels.Conditions}}</h3>
        </header>
        <div class="condition-chips">
          {{#each conditions.active as |condition|}}
          <span class="condition-chip {{#if condition.automatic}}automatic{{/if}}">
            <i class="fa-solid fa-circle-dot"></i>
            <span>{{condition.label}}</span>
            {{#unless condition.automatic}}
            <button type="button" data-action="removeCondition" data-condition-id="{{condition.id}}" data-tooltip="{{@root.labels.RemoveCondition}}" aria-label="{{@root.labels.RemoveCondition}}">
              <i class="fa-solid fa-xmark"></i>
            </button>
            {{/unless}}
          </span>
          {{else}}
          <span class="condition-empty">{{@root.labels.NoConditions}}</span>
          {{/each}}
        </div>

        <details class="condition-picker">
          <summary>
            <i class="fa-solid fa-plus"></i>
            <span>{{labels.SelectCondition}}</span>
          </summary>
          <div class="condition-menu">
            {{#each conditions.options as |condition|}}
            <button type="button" data-action="addCondition" data-condition-id="{{condition.id}}" {{#if condition.active}}disabled{{/if}}>
              {{condition.label}}
            </button>
            {{/each}}
          </div>
        </details>

        <div class="condition-controls">
          <span>{{labels.PsycheDamage}} {{psycheDamage.value}} / {{psycheDamage.max}}</span>
          <button type="button" data-action="psycheDamage" data-delta="1" data-tooltip="{{labels.AddPsycheDamage}}" aria-label="{{labels.AddPsycheDamage}}">
            <i class="fa-solid fa-plus"></i>
          </button>
          <button type="button" data-action="psycheDamage" data-delta="-1" data-tooltip="{{labels.ReducePsycheDamage}}" aria-label="{{labels.ReducePsycheDamage}}">
            <i class="fa-solid fa-minus"></i>
          </button>
          <button type="button" data-action="clearPsycheDamage" class="text-button" data-tooltip="{{labels.ClearCondition}}">
            {{labels.ClearCondition}}
          </button>
        </div>
      </section>

      <section class="rail-card armor-summary-card {{#if equippedArmor}}armor-equipped{{/if}}">
        <header>
          <i class="fa-solid fa-shield"></i>
          <h3>{{labels.EquippedArmor}}</h3>
        </header>
        {{#if equippedArmor}}
        <div class="armor-summary">
          <strong>{{equippedArmor.name}}</strong>
          <dl>
            <div><dt>{{labels.ArmorDefense}}</dt><dd>+{{equippedArmor.system.defenseBonus}}</dd></div>
            <div><dt>{{labels.MaxDexBonus}}</dt><dd>{{equippedArmor.system.maxDexBonus}}</dd></div>
            <div><dt>{{labels.ArmorPenalty}}</dt><dd>{{equippedArmor.system.armorPenalty}}</dd></div>
            <div><dt>{{labels.Bulk}}</dt><dd>{{equippedArmor.bulk}}</dd></div>
          </dl>
        </div>
        {{else}}
        <div class="condition-empty">{{labels.NoArmorEquipped}}</div>
        <button type="button" class="rail-action" data-action="addItem" data-item-type="armor">
          <i class="fa-solid fa-plus"></i>
          <span>{{labels.AddArmor}}</span>
        </button>
        {{/if}}
      </section>

      <section class="rail-card metric-card">
        <header>
          <i class="fa-solid fa-person-running"></i>
          <h3>{{labels.Movement}}</h3>
        </header>
        <output>{{system.movement}}<span>ft</span></output>
      </section>

      <section class="rail-card initiative-card">
        <header>
          <i class="fa-solid fa-dice-d20"></i>
          <h3>{{labels.Initiative}}</h3>
        </header>
        <button type="button" class="rail-action" data-action="rollInitiative" data-tooltip="{{labels.RollInitiative}}">
          <i class="fa-solid fa-bolt"></i>
          <span>{{labels.Roll}}</span>
        </button>
      </section>

      <section class="rail-card defenses-card">
        <header>
          <i class="fa-solid fa-shield-halved"></i>
          <h3>{{labels.Defenses}}</h3>
        </header>
        <ul class="defense-list">
          {{#each baseEntries as |base|}}
          <li>
            <span>{{base.label}}</span>
            <strong>{{base.defense}}</strong>
          </li>
          {{/each}}
        </ul>
      </section>

    </div>
  </aside>

  <header class="identity-bar">
    <div class="identity-main">
      <label class="sr-only" for="{{actor.id}}-name">{{labels.CharacterName}}</label>
      <input id="{{actor.id}}-name" type="text" class="character-name" name="name" value="{{actor.name}}" placeholder="{{labels.CharacterName}}" />
    </div>
    <div class="level-control">
      <label for="{{actor.id}}-level">{{labels.LevelAbbr}}</label>
      <input id="{{actor.id}}-level" type="number" name="system.level" value="{{system.level}}" min="1" />
    </div>
    <button type="button" class="theme-toggle" data-action="toggleTheme" data-tooltip="{{labels.ToggleTheme}}" aria-label="{{labels.ToggleTheme}}">
      {{#if (eq theme "dark")}}<i class="fa-solid fa-sun"></i>{{else}}<i class="fa-solid fa-moon"></i>{{/if}}
    </button>
  </header>

  <nav class="sheet-tabs" role="tablist" aria-label="{{labels.CharacterName}}">
    {{#each tabs as |tab|}}
    <button type="button"
            class="sheet-tab {{#if tab.active}}active{{/if}}"
            data-action="setTab"
            data-tab="{{tab.id}}"
            role="tab"
            aria-selected="{{#if tab.active}}true{{else}}false{{/if}}"
            data-tooltip="{{tab.label}}">
      <i class="{{tab.icon}}"></i>
      <span>{{tab.label}}</span>
    </button>
    {{/each}}
  </nav>

  <section class="console-body">
    <div class="console-scroll">

      {{#if (eq activeTab "bases")}}
      <section class="sheet-panel bases-panel" role="tabpanel">
        <header class="panel-heading">
          <h2>{{labels.Bases}}</h2>
        </header>
        <div class="base-grid">
          {{#each baseEntries as |base|}}
          <article class="base-card">
            <label for="{{../actor.id}}-base-{{base.key}}">{{base.label}}</label>
            <input id="{{../actor.id}}-base-{{base.key}}" type="number" name="system.bases.{{base.key}}" value="{{base.value}}" min="0" />
            {{#with base.lastRoll as |lr|}}
            <div class="last-roll {{#if lr.degree}}degree-{{lr.degree}}{{/if}}">
              <span>{{@root.labels.LastRoll}}</span>
              <strong>{{lr.total}}</strong>
            </div>
            {{/with}}
            <label class="die-row" for="{{../actor.id}}-base-{{base.key}}-die" data-tooltip="{{@root.labels.SelectDieSize}}">
              <span class="die-label">{{@root.labels.DieSize}}</span>
              <select id="{{../actor.id}}-base-{{base.key}}-die"
                      data-stat-key="{{base.key}}"
                      data-dtype="Number"
                      class="die-selector">
                {{#each base.dieOptions as |opt|}}
                <option value="{{opt.size}}" {{#if opt.selected}}selected{{/if}}>d{{opt.size}}</option>
                {{/each}}
              </select>
            </label>
            <button type="button" data-action="rollBase" data-base="{{base.key}}">
              <i class="fa-solid fa-dice-d20"></i>
              <span>{{@root.labels.Roll}} {{base.value}}d{{base.dieSize}}</span>
            </button>
          </article>
          {{/each}}
        </div>

        {{#if substats.length}}
        <section class="substats-panel" aria-label="{{labels.StaminaSubstats}}">
          <header class="substats-heading">
            <h3>{{labels.StaminaSubstats}}</h3>
            <span class="substats-hint">Modifier &times; Stamina &rarr; effective dice</span>
          </header>
          <div class="substat-grid">
            {{#each substats as |sub|}}
            <article class="substat-card">
              <header class="substat-head">
                <span class="substat-name">{{sub.label}}</span>
                <span class="substat-dice" data-tooltip="{{@root.labels.SubstatDiceTooltip}}">{{sub.diceCount}}d{{sub.dieSize}}</span>
              </header>
              <div class="substat-mod">
                <label for="{{@root.actor.id}}-substat-{{sub.key}}">Mod</label>
                <input id="{{@root.actor.id}}-substat-{{sub.key}}"
                       type="number"
                       name="system.staminaSubstats.{{sub.key}}"
                       value="{{sub.modifier}}"
                       step="1"
                       min="-5"
                       max="5"
                       data-tooltip="{{@root.labels.SubstatModifierTooltip}}" />
              </div>
              {{#with sub.lastRoll as |lr|}}
              <div class="last-roll {{#if lr.degree}}degree-{{lr.degree}}{{/if}}">
                <span>{{@root.labels.LastRoll}}</span>
                <strong>{{lr.total}}</strong>
              </div>
              {{/with}}
              <label class="die-row" for="{{@root.actor.id}}-substat-{{sub.key}}-die" data-tooltip="{{@root.labels.SelectDieSize}}">
                <span class="die-label">{{@root.labels.DieSize}}</span>
                <select id="{{@root.actor.id}}-substat-{{sub.key}}-die"
                        data-stat-key="{{sub.key}}"
                        data-dtype="Number"
                        class="die-selector">
                  {{#each sub.dieOptions as |opt|}}
                  <option value="{{opt.size}}" {{#if opt.selected}}selected{{/if}}>d{{opt.size}}</option>
                  {{/each}}
                </select>
              </label>
              <button type="button" data-action="rollBase" data-base="{{sub.key}}">
                <i class="fa-solid fa-dice-d20"></i>
                <span>{{@root.labels.Roll}} {{sub.diceCount}}d{{sub.dieSize}}</span>
              </button>
            </article>
            {{/each}}
          </div>
        </section>
        {{/if}}
      </section>
      {{/if}}

      {{#if (eq activeTab "skills")}}
      <section class="sheet-panel skills-panel" role="tabpanel">
        <header class="panel-heading">
          <h2>{{labels.Skills}}</h2>
          <button type="button" data-action="addItem" data-item-type="skill">
            <i class="fa-solid fa-plus"></i>
            <span>{{labels.AddSkill}}</span>
          </button>
        </header>
        <ul class="console-list">
          {{#each skills as |s|}}
          <li class="console-row">
            <div class="row-main">
              <strong>{{s.name}}</strong>
              <span class="row-meta">
                <span>{{s.baseLabel}}</span>
                <span>{{s.trainingLabel}} d{{s.dieSize}}</span>
                <span>{{s.rollFormula}}</span>
              </span>
            </div>
            <div class="row-actions">
              <button type="button" data-action="rollSkill" data-item-id="{{s.id}}">{{@root.labels.Roll}}</button>
              <button type="button" class="icon-button" data-action="editItem" data-item-id="{{s.id}}" data-tooltip="{{@root.labels.Edit}}" aria-label="{{@root.labels.Edit}}"><i class="fa-solid fa-pen"></i></button>
              <button type="button" class="icon-button danger" data-action="deleteItem" data-item-id="{{s.id}}" data-tooltip="{{@root.labels.Delete}}" aria-label="{{@root.labels.Delete}}"><i class="fa-solid fa-trash"></i></button>
            </div>
          </li>
          {{else}}
          <li class="empty-row">{{@root.labels.EmptySkills}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      {{#if (eq activeTab "weapons")}}
      <section class="sheet-panel weapons-panel" role="tabpanel">
        <header class="panel-heading">
          <h2>{{labels.Weapons}}</h2>
          <button type="button" data-action="addItem" data-item-type="weapon">
            <i class="fa-solid fa-plus"></i>
            <span>{{labels.AddWeapon}}</span>
          </button>
        </header>
        <div class="bulk-meter {{bulk.state}}">
          <div>
            <strong>{{labels.TotalBulk}}</strong>
            <span>{{bulk.label}}</span>
          </div>
          <meter min="0" max="{{bulk.max}}" value="{{bulk.total}}"></meter>
        </div>
        {{#if bulk.sources.length}}
        <div class="bulk-sources">
          <span class="feature-title">{{labels.BulkSources}}</span>
          <ul>
            {{#each bulk.sources as |source|}}
            <li>
              <span>{{source.name}}</span>
              <small>{{source.typeLabel}}</small>
              <strong>{{source.totalBulk}}</strong>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
        <ul class="console-list">
          {{#each weapons as |w|}}
          <li class="console-row">
            <div class="row-main">
              <strong>{{w.name}}</strong>
              <span class="row-meta">
                <span>{{w.baseLabel}}</span>
                <span>{{w.trainingLabel}} d{{w.dieSize}}</span>
                <span>{{@root.labels.Bulk}} {{w.bulk}}</span>
                {{#if w.system.damageBonus}}<span>+{{w.system.damageBonus}} {{@root.labels.Damage}}</span>{{/if}}
              </span>
            </div>
            <div class="row-actions">
              <button type="button" data-action="attackWeapon" data-item-id="{{w.id}}">{{@root.labels.Attack}}</button>
              <button type="button" class="icon-button" data-action="editItem" data-item-id="{{w.id}}" data-tooltip="{{@root.labels.Edit}}" aria-label="{{@root.labels.Edit}}"><i class="fa-solid fa-pen"></i></button>
              <button type="button" class="icon-button danger" data-action="deleteItem" data-item-id="{{w.id}}" data-tooltip="{{@root.labels.Delete}}" aria-label="{{@root.labels.Delete}}"><i class="fa-solid fa-trash"></i></button>
            </div>
          </li>
          {{else}}
          <li class="empty-row">{{@root.labels.EmptyWeapons}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      {{#if (eq activeTab "inventory")}}
      <section class="sheet-panel inventory-panel" role="tabpanel">
        <header class="panel-heading">
          <h2>{{labels.Inventory}}</h2>
          <div class="button-cluster">
            <button type="button" data-action="addItem" data-item-type="inventory">
              <i class="fa-solid fa-plus"></i>
              <span>{{labels.AddInventory}}</span>
            </button>
            <button type="button" data-action="addItem" data-item-type="armor">
              <i class="fa-solid fa-shield"></i>
              <span>{{labels.AddArmor}}</span>
            </button>
          </div>
        </header>
        <div class="bulk-meter {{bulk.state}}">
          <div>
            <strong>{{labels.TotalBulk}}</strong>
            <span>{{bulk.label}}</span>
          </div>
          <meter min="0" max="{{bulk.max}}" value="{{bulk.total}}"></meter>
        </div>
        {{#if bulk.sources.length}}
        <div class="bulk-sources">
          <span class="feature-title">{{labels.BulkSources}}</span>
          <ul>
            {{#each bulk.sources as |source|}}
            <li>
              <span>{{source.name}}</span>
              <small>{{source.typeLabel}}</small>
              <strong>{{source.totalBulk}}</strong>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
        <ul class="console-list">
          {{#each inventory as |i|}}
          <li class="console-row">
            <div class="row-main">
              <strong>{{i.name}}</strong>
              <span class="row-meta">
                <span>x{{i.system.quantity}}</span>
                <span>{{@root.labels.Bulk}} {{i.bulk}} / {{i.totalBulk}}</span>
                <span>{{#if i.system.equipped}}{{@root.labels.Equipped}}{{else}}{{@root.labels.Unequipped}}{{/if}}</span>
              </span>
            </div>
            <div class="row-actions">
              <button type="button" class="icon-button" data-action="toggleEquip" data-item-id="{{i.id}}" data-tooltip="{{@root.labels.ToggleEquipped}}" aria-label="{{@root.labels.ToggleEquipped}}">
                {{#if i.system.equipped}}<i class="fa-solid fa-square-check"></i>{{else}}<i class="fa-regular fa-square"></i>{{/if}}
              </button>
              <button type="button" class="icon-button" data-action="editItem" data-item-id="{{i.id}}" data-tooltip="{{@root.labels.Edit}}" aria-label="{{@root.labels.Edit}}"><i class="fa-solid fa-pen"></i></button>
              <button type="button" class="icon-button danger" data-action="deleteItem" data-item-id="{{i.id}}" data-tooltip="{{@root.labels.Delete}}" aria-label="{{@root.labels.Delete}}"><i class="fa-solid fa-trash"></i></button>
            </div>
          </li>
          {{else}}
          <li class="empty-row">{{@root.labels.EmptyInventory}}</li>
          {{/each}}
        </ul>

        <header class="subpanel-heading">
          <h3>{{labels.Armor}}</h3>
        </header>
        <ul class="console-list">
          {{#each armors as |armor|}}
          <li class="console-row">
            <div class="row-main">
              <strong>{{armor.name}}</strong>
              <span class="row-meta">
                <span>{{@root.labels.ArmorDefense}} +{{armor.system.defenseBonus}}</span>
                <span>{{@root.labels.MaxDexBonus}} {{armor.system.maxDexBonus}}</span>
                <span>{{@root.labels.ArmorPenalty}} {{armor.system.armorPenalty}}</span>
                <span>{{@root.labels.Bulk}} {{armor.bulk}}</span>
                <span>{{#if armor.system.equipped}}{{@root.labels.Equipped}}{{else}}{{@root.labels.Unequipped}}{{/if}}</span>
              </span>
            </div>
            <div class="row-actions">
              <button type="button" class="icon-button" data-action="toggleArmorEquip" data-item-id="{{armor.id}}" data-tooltip="{{@root.labels.ToggleEquipped}}" aria-label="{{@root.labels.ToggleEquipped}}">
                {{#if armor.system.equipped}}<i class="fa-solid fa-shield-halved"></i>{{else}}<i class="fa-solid fa-shield"></i>{{/if}}
              </button>
              <button type="button" class="icon-button" data-action="editItem" data-item-id="{{armor.id}}" data-tooltip="{{@root.labels.Edit}}" aria-label="{{@root.labels.Edit}}"><i class="fa-solid fa-pen"></i></button>
              <button type="button" class="icon-button danger" data-action="deleteItem" data-item-id="{{armor.id}}" data-tooltip="{{@root.labels.Delete}}" aria-label="{{@root.labels.Delete}}"><i class="fa-solid fa-trash"></i></button>
            </div>
          </li>
          {{else}}
          <li class="empty-row">{{@root.labels.EmptyArmor}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      {{#if (eq activeTab "archetypes")}}
      <section class="sheet-panel archetypes-panel" role="tabpanel">
        <header class="panel-heading">
          <h2>{{labels.Archetypes}}</h2>
        </header>
        <div class="archetype-slot-grid">
          {{#each archetypeSlots as |slot|}}
          <article class="archetype-slot-card {{#if slot.item}}filled{{/if}}">
            <header>
              <h3>{{slot.label}}</h3>
              {{#unless slot.item}}
              <div class="button-cluster">
                {{#if slot.sample}}
                <button type="button" data-action="addSampleArchetype" data-archetype-slot="{{slot.key}}">
                  <i class="fa-solid fa-sparkles"></i>
                  <span>{{@root.labels.AddSampleArchetype}}</span>
                </button>
                {{/if}}
                <button type="button" data-action="addItem" data-item-type="{{slot.itemType}}" data-archetype-slot="{{slot.key}}">
                  <i class="fa-solid fa-plus"></i>
                  <span>{{#if (eq slot.key "subarchetype")}}{{@root.labels.AddSubArchetype}}{{else}}{{@root.labels.AddArchetype}}{{/if}}</span>
                </button>
              </div>
              {{/unless}}
            </header>
            {{#with slot.item as |a|}}
            <div class="row-main">
              <strong>{{a.name}}</strong>
              <span class="row-meta">
                <span>{{a.categoryLabel}}</span>
                <span>{{@root.labels.BaseBoosts}}: {{a.boostLabel}}</span>
              </span>
              {{#if a.system.description}}<div class="row-description">{{{a.system.description}}}</div>{{/if}}
              {{#if a.grantedFeatures.length}}
              <div class="feature-list">
                <span class="feature-title">{{@root.labels.GrantedFeatures}}</span>
                {{#each a.grantedFeatures as |feature|}}
                <article>
                  <strong>{{feature.name}}</strong>
                  <p>{{feature.description}}</p>
                </article>
                {{/each}}
              </div>
              {{/if}}
            </div>
            <div class="row-actions">
              <button type="button" class="icon-button" data-action="editItem" data-item-id="{{a.id}}" data-tooltip="{{@root.labels.Edit}}" aria-label="{{@root.labels.Edit}}"><i class="fa-solid fa-pen"></i></button>
              <button type="button" class="icon-button danger" data-action="deleteItem" data-item-id="{{a.id}}" data-tooltip="{{@root.labels.Delete}}" aria-label="{{@root.labels.Delete}}"><i class="fa-solid fa-trash"></i></button>
            </div>
            {{else}}
            <div class="empty-row">{{@root.labels.EmptyArchetypeSlot}}</div>
            {{/with}}
          </article>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if (eq activeTab "biography")}}
      <section class="sheet-panel biography-panel" role="tabpanel">
        <header class="panel-heading">
          <h2>{{labels.Biography}}</h2>
        </header>
        <textarea name="system.biography" placeholder="{{labels.BiographyPlaceholder}}">{{system.biography}}</textarea>
      </section>
      {{/if}}

    </div>
  </section>

</form>
