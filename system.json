{
  "id": "astrolysis",
  "title": "Astrolysis",
  "description": "Dice-pool sci-fi/psionic RPG. Roll a base-sized pool using the referenced base or skill die.",
  "version": "0.5.1",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "authors": [
    { "name": "Gary" }
  ],
  "esmodules": ["astrolysis.mjs"],
  "styles": ["styles/system.css"],
  "languages": [
    { "lang": "en", "name": "English", "path": "lang/en.json" }
  ],
  "documentTypes": {
    "Actor": {
      "character": { "htmlFields": ["biography"] },
      "npc":       { "htmlFields": ["biography", "tactics"] }
    },
    "Item": {
      "archetype": { "htmlFields": ["description"] },
      "subarchetype": { "htmlFields": ["description"] },
      "skill":     { "htmlFields": ["description"] },
      "weapon":    { "htmlFields": ["description"] },
      "armor":     { "htmlFields": ["description"] },
      "inventory": { "htmlFields": ["description"] }
    }
  },
  "primaryTokenAttribute": "health",
  "secondaryTokenAttribute": "madness",
  "grid": { "distance": 5, "units": "ft" },
  "initiative": "1d4",

  "url": "https://github.com/darkclone9/foundry-astrolysis",
  "manifest": "https://github.com/darkclone9/foundry-astrolysis/raw/main/system.json",
  "download": "https://github.com/darkclone9/foundry-astrolysis/archive/refs/heads/main.zip",
  "bugs": "https://github.com/darkclone9/foundry-astrolysis/issues",
  "readme": "https://github.com/darkclone9/foundry-astrolysis/blob/main/README.md",
  "license": "https://github.com/darkclone9/foundry-astrolysis/blob/main/LICENSE"
}
